<?xml version="1.0" encoding="UTF-8"?>

<templates>
    <t t-name="dtm_ordenes_compra.extraordinariaDialogo" owl="1">
        <div class="rmc-overlay">
            <div class="rmc-dialog">
                <div class="rmc-icon-wrap">
                    <i class="fa fa-credit-card" style="font-size: 28px; color: rgba(214, 225, 84, 0.7);" aria-hidden="true"></i>
                </div>
                <h3>Compra Extraordinaría</h3>
                <p>Esta compra pasa directamente a Transito<strong style="color:#fff;">1240</strong> como lista?</p>

                <div class="rmc-form" t-ref="formRef">
                    <div class="rmc-field">
                        <label>Proveedor</label>
                        <input name="proveedor" type="text" class="rmc-input" placeholder="Nombre del proveedor"/>
                    </div>
                    <div class="rmc-field">
                        <label>Precio</label>
                        <input name="precio" type="number" step="0.01" class="rmc-input" placeholder="0.00"/>
                    </div>
                    <div class="rmc-field">
                        <label>Orden de compra</label>
                        <input name="orden_compra" type="text" class="rmc-input" placeholder="Orden de compra"/>
                    </div>
                </div>

                <div class="rmc-btn-row">
                    <button class="rmc-btn-cancel" t-on-click="props.cerrar">Cancelar</button>
                    <button class="rmc-btn-confirm" t-on-click="(ev) => this.mandarComprar(ev)">Aceptar</button>
                </div>
            </div>
        </div>
    </t>
</templates>
