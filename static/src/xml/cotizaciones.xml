<template xml:space="preserve">
    <t t-name="dtm_ordenes_compra.cotizaciones" owl="1">
        
        <table class="table table-striped table-bordered table-hover table-sm">
            <thead class="table-dark">
                <tr>
                    <th>Cotización</th>
                    <th>Fecha Entrega</th>
                    <th>Proveedor</th>
                    <th>Cliente</th>
                    <th>P.O.</th>
                    <th>Precio</th>
                    <th>Fecha Entrada</th>
                    <th>Status</th>
                </tr>
            </thead>
            <tbody>
            <!-- Filtros -->
                <tr>
                    <td>
                        <input type="number" min ="0" t-on-input="(ev) => this.cotizacionFiltro(ev)"/>
                    </td>
                    <!-- Fecha de entrega -->
                    <td>
                        <input type="date" name="fentrega_filtro" t-on-input="(ev) => this.fechaEntregaFiltro(ev)"/>
                    </td>
                    <td>
                        <select name="proveedor_filtro" t-on-change="(ev) => this.proveedorFiltro(ev)">
                            <option value="">--</option>
                            <option value="dtm">DTM</option>
                            <option value="mtd">MTD</option>                           
                        </select>
                    </td> 
                    <!-- Cliente -->
                    <td>
                        <select name="cliente_filtro" t-on-change="(ev) => this.clienteFiltro(ev)" >
                            <option value="">--</option>
                            <t t-foreach="state.clientes" t-as="cliente" t-key="cliente">
                                <option t-att-value="cliente">
                                    <t t-esc="cliente"/>
                                </option>
                            </t>
                        </select>
                    </td>
                     <!-- PO -->
                    <td >
                        <input type="text" min ="0" t-on-input="(ev) => this.poFiltro(ev)"/>
                    </td>
                    <td></td>
                    <td>
                        <input type="date" name="fentrada_filtro" t-on-input="(ev) => this.fechaEntradaFiltro(ev)"/>
                    </td>
                    <td>
                    </td>
                </tr>
                <t t-foreach="this.state.cotizaciones" t-as="cotizacion" t-key="cotizacion.cotizacion">
                    <tr t-on-click="()=>this.ordenesTrabajo(cotizacion.cotizacion,cotizacion.precio)">
                        <td><t t-esc="cotizacion.cotizacion"/></td>
                        <td><t t-esc="cotizacion.fecha_salida"/></td>
                        <td><t t-esc="cotizacion.proveedor"/></td>
                        <td><t t-esc="cotizacion.cliente"/></td>
                        <td><t t-esc="cotizacion.po"/></td>
                        <td><t t-esc="cotizacion.precio"/></td>
                        <td><t t-esc="cotizacion.fecha_entrada"/></td>
                        <td><t t-esc="cotizacion.status"/></td>
                    </tr>                    
                </t>
            </tbody>
        </table>

        <div>
            <t t-if="this.state.ordenes_dialogo">
               <OrdenesTrabajo cerrar="cerrarOrdenesTrabajo" cotizacion="this.state.cotizacion" po_costo="this.state.po_costo"/>
            </t>
        </div>
    </t>
</template>
